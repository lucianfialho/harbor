{
  "name": "@harbor/stage-local",
  "version": "0.0.1",
  "description": "Local filesystem staging layer for development and small migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test":  "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@harbor/core": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
